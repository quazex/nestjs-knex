{
  "name": "@quazex/nestjs-knex",
  "repository": {
    "type": "git",
    "url": "git://github.com/quazex/nestjs-knex.git"
  },
  "description": "NestJS module for Knex library",
  "version": "1.3.0",
  "author": "Alexander Smirnov",
  "license": "MIT",
  "engines": {
    "node": ">= 24.x"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**"
  ],
  "keywords": [
    "knex",
    "pg",
    "mysql",
    "sqlite",
    "oracledb",
    "nestjs",
    "nest",
    "typescript",
    "nodejs",
    "node"
  ],
  "scripts": {
    "build:clear": "rimraf lib",
    "build:compile": "npm run build:clear && tsc --project tsconfig.build.json",
    "dev:watch": "tsc --watch",
    "dev:check": "tsc --noEmit",
    "dev:lint": "eslint",
    "dev:format": "npm run dev:lint -- --fix",
    "dev:test": "jest",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@nestjs/common": ">=9.0.0 <12.0.0",
    "knex": ">=3.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "9.9.0",
    "@jest/globals": "29.7.0",
    "@nestjs/common": "11.1.17",
    "@nestjs/testing": "11.1.17",
    "@quazex/eslint-config": "1.1.3",
    "@testcontainers/postgresql": "11.13.0",
    "@types/pg": "8.20.0",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "knex": "3.1.0",
    "pg": "8.20.0",
    "rimraf": "6.1.3",
    "testcontainers": "11.13.0",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
